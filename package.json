{
  "name": "portable",
  "type": "module",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev:app": "bun run --filter @portable/app dev",
    "dev:pod-server": "bun run --filter @portable/pod-server dev",
    "dev:editor": "bun run --filter @portable/editor dev",
    "build:app": "bun run --filter @portable/app build",
    "build:pod-server": "bun run --filter @portable/pod-server build",
    "build:editor": "bun run --filter @portable/editor build",
    "build": "bun run --filter '*' build",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "bun run --filter '*' test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1"
  }
}
