{
  "name": "portable",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "scripts": {
    "dev:app": "pnpm --filter @portable/app dev",
    "dev:pod-server": "pnpm --filter @portable/pod-server dev",
    "dev:editor": "pnpm --filter @portable/editor dev",
    "build:app": "pnpm --filter @portable/app build",
    "build:pod-server": "pnpm --filter @portable/pod-server build",
    "build:editor": "pnpm --filter @portable/editor build",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "pnpm -r run test",
    "prepare": "husky"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.6.1",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.1"
  }
}
